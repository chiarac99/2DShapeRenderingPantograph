// Active shape (pointer + length).
float[][] shape;
int N_POINTS;
String shapeName;

void setShape(int id) {
  switch (id) {
    case 0: shape = shape_bunny;  shapeName = "BUNNY";  break;
    case 1: shape = shape_hammer; shapeName = "HAMMER"; break;
    case 2: shape = shape_pear;   shapeName = "PEAR";   break;
  }
  N_POINTS = shape.length;
  precomputeArcLength();
  println("Active shape: " + shapeName + " (" + N_POINTS + " pts)");

  // Tell Arduino too, if connected.
  if (arduinoPort != null) {
    if (id == 0)      arduinoPort.write('B');
    else if (id == 1) arduinoPort.write('H');
    else if (id == 2) arduinoPort.write('P');
  }
}


// Precomputed arc-length table (sized for max possible):
float[] s_arc;
float perimeter;
float lambda_actual;


// ---------- VELOCITY TRACKING ----------
float xh_prev = 0, yh_prev = 0;
float vx_filt = 0, vy_filt = 0;
float DT_LOOP = 0.001f;


// ---------- SERIAL ----------
Serial arduinoPort = null;
float arduinoFx = 0, arduinoFy = 0;


// =============================================================
// SETUP
// =============================================================
void setup() {
  size(900, 900);
  ORIGIN_X = width / 2.0f;
  ORIGIN_Y = height / 2.0f;

  setShape(0);   // start with bunny
  setupSerial();
}


// =============================================================
// DRAW LOOP
// =============================================================
void draw() {
  background(245);

  float xh = (mouseX - ORIGIN_X) / PIXELS_PER_METER;
  float yh = -(mouseY - ORIGIN_Y) / PIXELS_PER_METER;

  float vx_raw = (xh - xh_prev) / DT_LOOP;
  float vy_raw = (yh - yh_prev) / DT_LOOP;
  vx_filt = 0.9f * vx_raw + 0.1f * vx_filt;
  vy_filt = 0.9f * vy_raw + 0.1f * vy_filt;
  xh_prev = xh;
  yh_prev = yh;

  float[] F;
  float signedDepth;
  if (STANDALONE_MODE) {
    F = computeForceStandalone(xh, yh);
  } else {
    sendMouseToArduino(xh, yh);
    F = new float[]{arduinoFx, arduinoFy};
    computeForceStandalone(xh, yh);  // also run locally for HUD depth value
  }
  signedDepth = lastSignedDepth;

  drawGuidanceRegion();
  drawDeadZone();
  drawShape();
  drawPenTip(xh, yh);
  drawForceArrow(xh, yh, F[0], F[1]);
  drawHUD(xh, yh, F[0], F[1], signedDepth);
}


// =============================================================
// FORCE MODEL (standalone)
// =============================================================
float lastSignedDepth = 0;

float[] computeForceStandalone(float x, float y) {
  float[] result = findNearestSegment(x, y);
  float unsigned_d = result[0];
  float nx = result[1];
  float ny = result[2];
  float t_frac = result[3];
  int seg_i = (int) result[4];

  boolean inside = isInsidePolygon(x, y);
  float d = inside ? unsigned_d : -unsigned_d;
  lastSignedDepth = d;

  float v_inward = -(vx_filt * nx + vy_filt * ny);

  float Fx = 0, Fy = 0;

  if (d > 0.0f) {
    float F_wall_mag = K_WALL * d;
    if (v_inward > 0.0f) F_wall_mag += B_WALL * v_inward;
    Fx = F_wall_mag * nx;
    Fy = F_wall_mag * ny;

    if (texturedMode) {
      int next_i = (seg_i + 1) % N_POINTS;
      float seg_len = (next_i == 0) ? (perimeter - s_arc[seg_i])
                                    : (s_arc[next_i] - s_arc[seg_i]);
      float s = s_arc[seg_i] + t_frac * seg_len;
      float F_tex = A_TEX * sin(2 * PI * s / lambda_actual);
      Fx += F_tex * nx;
      Fy += F_tex * ny;
    }
  } else if (d > P_T) {
    Fx = 0; Fy = 0;
  } else {
    float F_guide = A_GUIDE * exp(-C_GUIDE * (d - P_T));
    if (F_guide > F_GUIDE_MAX) F_guide = F_GUIDE_MAX;
    Fx = -F_guide * nx;
    Fy = -F_guide * ny;
  }

  return new float[]{Fx, Fy};
}


float[] findNearestSegment(float x, float y) {
  int best_i = 0;
  float best_dist = 1e9f;
  float best_nx = 0, best_ny = 0, best_t = 0;

  for (int i = 0; i < N_POINTS; i++) {
    int j = (i + 1) % N_POINTS;
    float ax = shape[i][0], ay = shape[i][1];
    float bx = shape[j][0], by = shape[j][1];
    float tx = bx - ax;
    float ty = by - ay;
    float seg_len2 = tx*tx + ty*ty;

    float t = ((x - ax)*tx + (y - ay)*ty) / seg_len2;
    if (t < 0) t = 0;
    if (t > 1) t = 1;

    float px = ax + t*tx;
    float py = ay + t*ty;
    float ddx = x - px;
    float ddy = y - py;
    float d = sqrt(ddx*ddx + ddy*ddy);

    if (d < best_dist) {
      best_dist = d;
      best_i = i;
      best_t = t;
      float seg_len = sqrt(seg_len2);
      // Outward normal for a CCW polygon in math (y-up) coords:
      // rotate tangent -90 deg, i.e. (tx, ty) -> (ty, -tx).
      best_nx =  ty / seg_len;
      best_ny = -tx / seg_len;
    }
  }
  return new float[]{best_dist, best_nx, best_ny, best_t, best_i};
}


boolean isInsidePolygon(float x, float y) {
  boolean inside = false;
  for (int i = 0, j = N_POINTS - 1; i < N_POINTS; j = i++) {
    float xi = shape[i][0], yi = shape[i][1];
    float xj = shape[j][0], yj = shape[j][1];
    boolean intersect = ((yi > y) != (yj > y)) &&
                       (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
    if (intersect) inside = !inside;
  }
  return inside;
}


void precomputeArcLength() {
  s_arc = new float[N_POINTS];
  s_arc[0] = 0;
  for (int i = 1; i < N_POINTS; i++) {
    float dx = shape[i][0] - shape[i-1][0];
    float dy = shape[i][1] - shape[i-1][1];
    s_arc[i] = s_arc[i-1] + sqrt(dx*dx + dy*dy);
  }
  float dx_close = shape[0][0] - shape[N_POINTS-1][0];
  float dy_close = shape[0][1] - shape[N_POINTS-1][1];
  perimeter = s_arc[N_POINTS-1] + sqrt(dx_close*dx_close + dy_close*dy_close);

  int n_cycles = round(perimeter / LAMBDA_TEX);
  if (n_cycles < 1) n_cycles = 1;
  lambda_actual = perimeter / n_cycles;
  println("Perimeter: " + perimeter + " m, " + n_cycles + " texture cycles, " +
          "lambda = " + lambda_actual + " m");
}


// =============================================================
// VISUAL RENDERING
// =============================================================
float meterToPixelX(float xm) { return ORIGIN_X + xm * PIXELS_PER_METER; }
float meterToPixelY(float ym) { return ORIGIN_Y - ym * PIXELS_PER_METER; }

void drawShape() {
  // Fill the inside with a faint color to indicate "wall force region"
  // (d > 0; linear spring pushing user outward).
  fill(240, 230, 220, 200);
  stroke(40);
  strokeWeight(2);
  beginShape();
  for (int i = 0; i < N_POINTS; i++) {
    vertex(meterToPixelX(shape[i][0]), meterToPixelY(shape[i][1]));
  }
  endShape(CLOSE);
}

// Helper: draw the outline offset outward by `offset` meters, with thick
// stroke `bandWidth` meters. Net effect is a band whose inner edge sits
// at distance `offset - bandWidth/2` from the outline, and outer edge at
// `offset + bandWidth/2`.  For a clean "entirely outside" band, set
// offset = bandWidth/2.
//
// Uses vertex-normal offsetting; can produce small artifacts at sharp
// concavities, but with modest offset values these are barely noticeable
// compared to the spiky polygon-offset approach we had before.
void drawOutlineBand(float offset, float bandWidth, int r, int g, int b, int alpha) {
  noFill();
  stroke(r, g, b, alpha);
  strokeWeight(bandWidth * PIXELS_PER_METER);
  beginShape();
  for (int i = 0; i < N_POINTS; i++) {
    int prev = (i - 1 + N_POINTS) % N_POINTS;
    float tx1 = shape[i][0] - shape[prev][0];
    float ty1 = shape[i][1] - shape[prev][1];
    float L1 = sqrt(tx1*tx1 + ty1*ty1);
    int next = (i + 1) % N_POINTS;
    float tx2 = shape[next][0] - shape[i][0];
    float ty2 = shape[next][1] - shape[i][1];
    float L2 = sqrt(tx2*tx2 + ty2*ty2);
    // Outward normal at vertex = avg of adjacent edge outward normals
    // (for CCW polygon: rotate tangent -90 deg -> (ty, -tx))
    float nx =  ((ty1/L1) + (ty2/L2)) / 2.0f;
    float ny = -((tx1/L1) + (tx2/L2)) / 2.0f;
    float L = sqrt(nx*nx + ny*ny);
    if (L < 1e-9f) continue;
    nx /= L; ny /= L;
    float x = shape[i][0] + nx * offset;
    float y = shape[i][1] + ny * offset;
    vertex(meterToPixelX(x), meterToPixelY(y));
  }
  endShape(CLOSE);
}

void drawDeadZone() {
  // Band entirely outside the outline, from d=0 to d=P_T (3 mm wide).
  float w = abs(P_T);            // 3 mm
  drawOutlineBand(w * 0.5f, w, 180, 220, 255, 180);
}

void drawGuidanceRegion() {
  // Guidance band: from d=P_T outward to the saturation distance.
  // Saturation is at d = P_T - ln(F_GUIDE_MAX/A_GUIDE)/C_GUIDE
  // = -0.003 - ln(2/0.5)/200 = -0.003 - 0.00693 = -0.00993 m.
  // So the guidance region is from d = -0.003 to d = -0.010, width ~7 mm.
  float w = 0.007f;
  float midOffset = abs(P_T) + w * 0.5f;  // band center is 6.5 mm outside outline
  drawOutlineBand(midOffset, w, 255, 200, 200, 80);
}

void drawPenTip(float xh, float yh) {
  noStroke();
  fill(255, 100, 150);
  ellipse(meterToPixelX(xh), meterToPixelY(yh), 12, 12);
}

void drawForceArrow(float xh, float yh, float Fx, float Fy) {
  float Fmag = sqrt(Fx*Fx + Fy*Fy);
  if (Fmag < 1e-4f) return;
  float SCALE = 50.0f;
  float x1 = meterToPixelX(xh);
  float y1 = meterToPixelY(yh);
  float x2 = x1 + Fx * SCALE;
  float y2 = y1 - Fy * SCALE;
  stroke(40, 160, 80);
  strokeWeight(3);
  line(x1, y1, x2, y2);
  float angle = atan2(y2 - y1, x2 - x1);
  pushMatrix();
  translate(x2, y2);
  rotate(angle);
  triangle(0, 0, -10, -5, -10, 5);
  popMatrix();
}

void drawHUD(float xh, float yh, float Fx, float Fy, float signedDepth) {
  noStroke();
  fill(255, 255, 255, 220);
  rect(10, 10, 280, 180);
  fill(20);
  textSize(13);
  text("SHAPE: " + shapeName, 20, 30);
  text("MODE: " + (STANDALONE_MODE ? "STANDALONE" : "HARDWARE"), 20, 50);
  text("RENDER: " + (texturedMode ? "TEXTURED" : "CONTROL"), 20, 70);
  text(String.format("Pen tip: (%.4f, %.4f) m", xh, yh), 20, 95);
  text(String.format("Signed depth: %.4f m", signedDepth), 20, 115);
  text(String.format("Force: (%.3f, %.3f) N", Fx, Fy), 20, 135);
  text(String.format("|F|: %.3f N", sqrt(Fx*Fx + Fy*Fy)), 20, 155);

  fill(120);
  textSize(11);
  text("[B/H/P] shape  [T] texture  [M] mode  [R] reset", 20, height - 15);
}


// =============================================================
// SERIAL
// =============================================================
void setupSerial() {
  if (STANDALONE_MODE) return;
  String[] ports = Serial.list();
  println("Available serial ports:");
  for (int i = 0; i < ports.length; i++) {
    println("  [" + i + "] " + ports[i]);
  }
  if (ports.length == 0) {
    println("No serial ports found; staying in STANDALONE mode.");
    STANDALONE_MODE = true;
    return;
  }
  String portName = SERIAL_PORT_NAME.isEmpty() ? ports[0] : SERIAL_PORT_NAME;
  println("Connecting to: " + portName);
  arduinoPort = new Serial(this, portName, 115200);
  arduinoPort.bufferUntil('\n');
}

void sendMouseToArduino(float xh, float yh) {
  if (arduinoPort == null) return;
  arduinoPort.write(String.format("%.4f,%.4f\n", xh, yh));
}


// =============================================================
// INPUT
// =============================================================
void keyPressed() {
  if (key == 'b' || key == 'B') {
    setShape(0);
  } else if (key == 'h' || key == 'H') {
    setShape(1);
  } else if (key == 'p' || key == 'P') {
    setShape(2);
  } else if (key == 't' || key == 'T') {
    texturedMode = !texturedMode;
    println("texturedMode = " + texturedMode);
    if (arduinoPort != null) {
      arduinoPort.write(texturedMode ? 'T' : 'C');
    }
  } else if (key == 'm' || key == 'M') {
    STANDALONE_MODE = !STANDALONE_MODE;
    println("STANDALONE_MODE = " + STANDALONE_MODE);
    if (!STANDALONE_MODE && arduinoPort == null) setupSerial();
  } else if (key == 'r' || key == 'R') {
    xh_prev = 0; yh_prev = 0;
    vx_filt = 0; vy_filt = 0;
  }
}
